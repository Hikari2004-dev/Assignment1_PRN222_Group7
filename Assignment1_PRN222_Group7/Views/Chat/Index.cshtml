@using Assignment1_PRN222_Group7_DAL.Entities
@{
    ViewData["Title"] = "Trợ lý học tập AI (RAG)";
    var subjects = ViewBag.Subjects as IEnumerable<Subject> ?? new List<Subject>();
}

<!-- Google Fonts Outfit -->
<style>
    @@import url('https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap');

    .chat-wrapper {
        font-family: 'Outfit', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        display: flex;
        height: calc(100vh - 160px);
        min-height: 600px;
        background: rgba(255, 255, 255, 0.45);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid rgba(255, 255, 255, 0.25);
        border-radius: 20px;
        box-shadow: 0 12px 40px rgba(31, 38, 135, 0.08);
        overflow: hidden;
        margin-top: 10px;
        margin-bottom: 20px;
        transition: all 0.3s ease;
    }

    .chat-sidebar {
        flex: 0 0 320px;
        background: rgba(248, 249, 250, 0.85);
        border-right: 1px solid rgba(0, 0, 0, 0.08);
        display: flex;
        flex-direction: column;
        height: 100%;
        transition: all 0.3s ease;
    }

    .chat-sidebar-header {
        padding: 20px;
        border-bottom: 1px solid rgba(0, 0, 0, 0.06);
    }

    .chat-sidebar-content {
        flex: 1;
        overflow-y: auto;
        padding: 10px;
    }

    .chat-main {
        flex: 1;
        display: flex;
        flex-direction: column;
        background: rgba(255, 255, 255, 0.95);
        height: 100%;
        position: relative;
    }

    .chat-main-header {
        padding: 18px 24px;
        border-bottom: 1px solid rgba(0, 0, 0, 0.06);
        display: flex;
        align-items: center;
        justify-content: space-between;
        background: rgba(255, 255, 255, 0.8);
    }

    .chat-main-messages {
        flex: 1;
        overflow-y: auto;
        padding: 24px;
        display: flex;
        flex-direction: column;
        gap: 20px;
        background: #fafbfe;
    }

    .chat-main-input-area {
        padding: 20px 24px;
        border-top: 1px solid rgba(0, 0, 0, 0.06);
        background: #ffffff;
    }

    /* Session List Item */
    .session-item {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 14px 16px;
        border-radius: 12px;
        margin-bottom: 8px;
        cursor: pointer;
        transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
        border: 1px solid transparent;
        background: transparent;
    }

    .session-item:hover {
        background: rgba(0, 0, 0, 0.04);
        transform: translateY(-1px);
    }

    .session-item.active {
        background: linear-gradient(135deg, rgba(30, 60, 114, 0.08) 0%, rgba(42, 82, 152, 0.08) 100%);
        border: 1px solid rgba(30, 60, 114, 0.15);
    }

    .session-info {
        flex: 1;
        min-width: 0;
        margin-right: 10px;
    }

    .session-title {
        font-weight: 500;
        font-size: 0.95rem;
        color: #2c3e50;
        margin-bottom: 3px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .session-meta {
        font-size: 0.78rem;
        color: #7f8c8d;
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .session-delete-btn {
        opacity: 0;
        background: transparent;
        border: none;
        color: #e74c3c;
        padding: 4px 8px;
        border-radius: 6px;
        transition: all 0.2s ease;
    }

    .session-item:hover .session-delete-btn {
        opacity: 1;
    }

    .session-delete-btn:hover {
        background: rgba(231, 76, 60, 0.1);
        color: #c0392b;
    }

    /* Message Bubbles */
    .message-container {
        display: flex;
        flex-direction: column;
        max-width: 80%;
        animation: bubbleFadeIn 0.35s ease-out;
    }

    .message-container.user {
        align-self: flex-end;
    }

    .message-container.assistant {
        align-self: flex-start;
    }

    .message-bubble {
        padding: 14px 20px;
        border-radius: 18px;
        font-size: 0.98rem;
        line-height: 1.55;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.02);
    }

    .message-container.user .message-bubble {
        background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
        color: #ffffff;
        border-bottom-right-radius: 4px;
    }

    .message-container.assistant .message-bubble {
        background: #ffffff;
        color: #2c3e50;
        border-top-left-radius: 4px;
        border: 1px solid rgba(0, 0, 0, 0.06);
    }

    .message-meta {
        font-size: 0.75rem;
        color: #95a5a6;
        margin-top: 5px;
        margin-bottom: 2px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .message-container.user .message-meta {
        justify-content: flex-end;
    }

    /* Sources citation style */
    .sources-accordion {
        margin-top: 12px;
    }

    .sources-toggle-btn {
        background: #f8f9fa;
        border: 1px solid rgba(0, 0, 0, 0.08);
        border-radius: 10px;
        font-size: 0.82rem;
        font-weight: 500;
        color: #626d7a;
        padding: 8px 14px;
        transition: all 0.2s ease;
        display: flex;
        align-items: center;
        justify-content: space-between;
        width: 100%;
        text-align: left;
    }

    .sources-toggle-btn:hover {
        background: #f1f3f5;
        color: #2b3541;
        border-color: rgba(0, 0, 0, 0.12);
    }

    .sources-collapse-card {
        border: 1px solid rgba(0, 0, 0, 0.06);
        border-radius: 10px;
        background: #fafbfe;
        margin-top: 8px;
        padding: 12px;
    }

    .source-item {
        padding-bottom: 10px;
        margin-bottom: 10px;
        border-bottom: 1px dashed rgba(0, 0, 0, 0.08);
    }

    .source-item:last-child {
        border-bottom: none;
        margin-bottom: 0;
        padding-bottom: 0;
    }

    .source-title-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 6px;
    }

    .source-doc-name {
        font-weight: 600;
        color: #1e3c72;
        font-size: 0.82rem;
    }

    .source-score-badge {
        font-size: 0.72rem;
        background: #e8f5e9;
        color: #2e7d32;
        padding: 2px 8px;
        border-radius: 20px;
        font-weight: 600;
    }

    .source-excerpt {
        font-style: italic;
        color: #576574;
        font-size: 0.8rem;
        background: rgba(0, 0, 0, 0.02);
        padding: 8px 12px;
        border-radius: 6px;
        border-left: 3px solid #2a5298;
    }

    /* Skeleton Loading Thinking */
    .skeleton-thinking {
        display: flex;
        flex-direction: column;
        gap: 8px;
        width: 250px;
    }

    .skeleton-line {
        height: 12px;
        background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
        background-size: 200% 100%;
        animation: loadingShimmer 1.5s infinite;
        border-radius: 4px;
    }

    .skeleton-line.short {
        width: 60%;
    }

    .skeleton-line.medium {
        width: 85%;
    }

    /* Empty state */
    .empty-state {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        height: 100%;
        color: #7f8c8d;
        padding: 40px;
        animation: fadeIn 0.5s ease;
    }

    .empty-state i {
        font-size: 4rem;
        color: #bdc3c7;
        margin-bottom: 20px;
        background: linear-gradient(135deg, rgba(30, 60, 114, 0.1) 0%, rgba(42, 82, 152, 0.1) 100%);
        width: 100px;
        height: 100px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
    }

    .empty-state h4 {
        color: #2c3e50;
        margin-bottom: 10px;
    }

    /* Animations */
    @@keyframes bubbleFadeIn {
        from {
            opacity: 0;
            transform: translateY(8px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes loadingShimmer {
        from {
            background-position: 200% 0;
        }
        to {
            background-position: -200% 0;
        }
    }

    @@keyframes fadeIn {
        from { opacity: 0; }
        to { opacity: 1; }
    }

    /* Scrollbar Styling */
    .chat-sidebar-content::-webkit-scrollbar,
    .chat-main-messages::-webkit-scrollbar {
        width: 6px;
    }

    .chat-sidebar-content::-webkit-scrollbar-track,
    .chat-main-messages::-webkit-scrollbar-track {
        background: transparent;
    }

    .chat-sidebar-content::-webkit-scrollbar-thumb,
    .chat-main-messages::-webkit-scrollbar-thumb {
        background: rgba(0, 0, 0, 0.1);
        border-radius: 10px;
    }

    .chat-sidebar-content::-webkit-scrollbar-thumb:hover,
    .chat-main-messages::-webkit-scrollbar-thumb:hover {
        background: rgba(0, 0, 0, 0.2);
    }
</style>

<!-- FontAwesome CDN -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" integrity="sha512-iecdLmaskl7CVkqkXNQ/ZH/XLlvWZOJyj7Yy7tcenmpD1ypASozpmT/E0iPtmFIB46ZmdtAc9eNBvH0H/ZpiBw==" crossorigin="anonymous" referrerpolicy="no-referrer" />

<!-- Highlight.js Code Syntax Theme -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.7.0/styles/github-dark.min.css" />

<div class="chat-wrapper">
    <!-- Left Sidebar: Session List -->
    <div class="chat-sidebar">
        <div class="chat-sidebar-header">
            <button class="btn btn-primary w-100 rounded-pill py-2 shadow-sm d-flex align-items-center justify-content-center gap-2" 
                    data-bs-toggle="modal" data-bs-target="#newSessionModal">
                <i class="fa-solid fa-plus"></i>
                <span>Cuộc trò chuyện mới</span>
            </button>
        </div>
        <div class="chat-sidebar-content" id="sessionList">
            <!-- Sessions list loaded dynamically -->
            <div class="text-center py-4">
                <div class="spinner-border spinner-border-sm text-secondary" role="status"></div>
                <div class="text-muted small mt-2">Đang tải cuộc hội thoại...</div>
            </div>
        </div>
    </div>

    <!-- Right Side: Chat Area -->
    <div class="chat-main">
        <!-- Chat Header -->
        <div class="chat-main-header d-none" id="chatHeader">
            <div>
                <h5 class="mb-0 fw-bold text-dark" id="chatHeaderTitle">Chat Session</h5>
                <span class="badge bg-secondary-subtle text-secondary border mt-1" id="chatHeaderSubject">General Study</span>
            </div>
            <div>
                <button class="btn btn-outline-secondary btn-sm rounded-pill" onclick="reloadCurrentChat()">
                    <i class="fa-solid fa-rotate-right me-1"></i> Làm mới
                </button>
            </div>
        </div>

        <!-- Chat Messages -->
        <div class="chat-main-messages" id="chatMessages">
            <div class="empty-state">
                <i class="fa-solid fa-comments"></i>
                <h4>Hộp thoại trống</h4>
                <p>Hãy chọn một cuộc hội thoại từ menu bên trái hoặc bắt đầu một phiên chat mới để học tập cùng AI.</p>
            </div>
        </div>

        <!-- Chat Input -->
        <div class="chat-main-input-area d-none" id="chatInputArea">
            <form id="sendMessageForm" onsubmit="onSendMessage(event)">
                <div class="input-group">
                    <input type="text" class="form-control rounded-start-pill border-end-0 px-4 py-3" 
                           id="messageInput" placeholder="Hỏi AI bất kỳ kiến thức nào từ tài liệu..." autocomplete="off" />
                    <button class="btn btn-primary rounded-end-pill px-4" type="submit" id="sendBtn">
                        <i class="fa-solid fa-paper-plane"></i>
                    </button>
                </div>
                <div class="form-text text-muted small mt-2 text-center">
                    <i class="fa-solid fa-circle-info me-1"></i> Trợ lý AI sẽ tự động tìm kiếm và trích dẫn thông tin từ các tài liệu môn học đã đăng tải.
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal: Start New Chat Session -->
<div class="modal fade" id="newSessionModal" tabindex="-1" aria-labelledby="newSessionModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 16px;">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold" id="newSessionModalLabel">Bắt đầu phiên học mới</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="createSessionForm" onsubmit="onCreateSession(event)">
                <div class="modal-body py-4">
                    <div class="mb-3">
                        <label for="sessionTitleInput" class="form-label fw-semibold">Tên phiên chat (Tùy chọn)</label>
                        <input type="text" class="form-control rounded-3" id="sessionTitleInput" placeholder="Ví dụ: Ôn tập chương 1 Toán rời rạc" />
                    </div>
                    <div class="mb-3">
                        <label for="subjectSelectInput" class="form-label fw-semibold">Giới hạn tài liệu theo Môn học</label>
                        <select class="form-select rounded-3" id="subjectSelectInput">
                            <option value="">-- Tất cả môn học (Hỏi tự do) --</option>
                            @foreach (var subject in subjects)
                            {
                                <option value="@subject.Id">@subject.Code - @subject.Name</option>
                            }
                        </select>
                        <div class="form-text mt-1 text-muted">Hệ thống sẽ chỉ trích dẫn tài liệu thuộc môn học được chọn.</div>
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">Hủy bỏ</button>
                    <button type="submit" class="btn btn-primary rounded-pill px-4 shadow-sm" id="createSessionBtn">Bắt đầu chat</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <!-- Marked.js for Markdown parsing -->
    <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
    
    <!-- Highlight.js for Code Highlight -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.7.0/highlight.min.js"></script>

    <script>
        // Configure marked options
        marked.setOptions({
            gfm: true,
            breaks: true,
            highlight: function(code, lang) {
                const language = hljs.getLanguage(lang) ? lang : 'plaintext';
                return hljs.highlight(code, { language }).value;
            }
        });

        let activeSessionId = null;

        $(document).ready(function () {
            loadSessions();
        });

        // Load sessions list in sidebar
        function loadSessions() {
            $.get("/Chat/GetSessions", function (sessions) {
                const list = $("#sessionList");
                list.empty();

                if (sessions.length === 0) {
                    list.html('<div class="text-center text-muted py-5 px-3"><i class="fa-regular fa-comments fs-3 mb-2 d-block"></i>Chưa có cuộc trò chuyện nào. Hãy tạo mới!</div>');
                    return;
                }

                sessions.forEach(s => {
                    const isActive = s.id === activeSessionId ? 'active' : '';
                    const itemHtml = `
                        <div class="session-item ${isActive}" data-id="${s.id}" onclick="selectSession(${s.id})">
                            <div class="session-info">
                                <div class="session-title" title="${s.title}">${s.title}</div>
                                <div class="session-meta">
                                    <span class="badge bg-secondary-subtle text-secondary border px-2 py-1">${s.subjectName}</span>
                                    <span>• ${s.totalMessages} tin nhắn</span>
                                </div>
                            </div>
                            <button class="session-delete-btn" onclick="onDeleteSession(event, ${s.id})" title="Xóa cuộc chat">
                                <i class="fa-solid fa-trash-can"></i>
                            </button>
                        </div>
                    `;
                    list.append(itemHtml);
                });
            }).fail(function () {
                $("#sessionList").html('<div class="text-center text-danger py-4 px-3"><i class="fa-solid fa-circle-exclamation fs-4 mb-2 d-block"></i>Lỗi tải cuộc trò chuyện</div>');
            });
        }

        // Select a session
        function selectSession(sessionId) {
            activeSessionId = sessionId;
            $(".session-item").removeClass("active");
            $(`.session-item[data-id="${sessionId}"]`).addClass("active");

            // Show active header and input area
            $("#chatHeader").removeClass("d-none");
            $("#chatInputArea").removeClass("d-none");

            // Update title and subject badge from list
            const activeItem = $(`.session-item[data-id="${sessionId}"]`);
            const title = activeItem.find(".session-title").text();
            const subject = activeItem.find(".session-meta span").text();
            $("#chatHeaderTitle").text(title);
            $("#chatHeaderSubject").text(subject);

            loadMessages(sessionId);
        }

        // Reload current chat
        function reloadCurrentChat() {
            if (activeSessionId) {
                loadMessages(activeSessionId);
            }
        }

        // Fetch messages of a session
        function loadMessages(sessionId) {
            const container = $("#chatMessages");
            container.html(`
                <div class="text-center py-5">
                    <div class="spinner-border text-primary" role="status"></div>
                    <div class="text-muted mt-2">Đang tải nội dung tin nhắn...</div>
                </div>
            `);

            $.get("/Chat/GetMessages", { sessionId: sessionId }, function (messages) {
                container.empty();

                if (messages.length === 0) {
                    container.html(`
                        <div class="empty-state">
                            <i class="fa-solid fa-message"></i>
                            <h4>Bắt đầu học tập</h4>
                            <p>Nhập câu hỏi của bạn vào khung bên dưới để trò chuyện cùng AI học tập.</p>
                        </div>
                    `);
                    return;
                }

                messages.forEach(msg => {
                    renderMessage(msg);
                });

                scrollToBottom();
            }).fail(function () {
                container.html('<div class="text-center text-danger py-5"><i class="fa-solid fa-triangle-exclamation fs-3 mb-2 d-block"></i>Không thể tải tin nhắn. Hãy thử lại.</div>');
            });
        }

        // Render a message bubble inside chat arena
        function renderMessage(msg) {
            const container = $("#chatMessages");
            const isUser = msg.role === "User";
            const roleClass = isUser ? "user" : "assistant";
            
            let contentHtml = "";
            if (isUser) {
                contentHtml = escapeHtml(msg.content);
            } else {
                contentHtml = marked.parse(msg.content);
            }

            let sourcesHtml = "";
            if (!isUser && msg.sources && msg.sources.length > 0) {
                const accordionId = `sources-collapse-${msg.id}`;
                const sourceItems = msg.sources.map((s, idx) => `
                    <div class="source-item">
                        <div class="source-title-row">
                            <span class="source-doc-name"><i class="fa-solid fa-file-pdf me-1"></i> [${idx + 1}] ${escapeHtml(s.documentTitle)} (Đoạn ${s.chunkIndex + 1})</span>
                            <span class="source-score-badge">Khớp: ${(s.similarityScore * 100).toFixed(0)}%</span>
                        </div>
                        <div class="source-excerpt">
                            "${escapeHtml(s.citedContent)}"
                        </div>
                    </div>
                `).join('');

                sourcesHtml = `
                    <div class="sources-accordion">
                        <button class="sources-toggle-btn collapsed" type="button" data-bs-toggle="collapse" 
                                data-bs-target="#${accordionId}" aria-expanded="false">
                            <span><i class="fa-solid fa-book-open-reader me-2"></i>Nguồn tài liệu trích dẫn (${msg.sources.length})</span>
                            <i class="fa-solid fa-chevron-down ms-2"></i>
                        </button>
                        <div class="collapse" id="${accordionId}">
                            <div class="sources-collapse-card">
                                ${sourceItems}
                            </div>
                        </div>
                    </div>
                `;
            }

            const msgHtml = `
                <div class="message-container ${roleClass}">
                    <div class="message-bubble">
                        <div class="message-text">${contentHtml}</div>
                        ${sourcesHtml}
                    </div>
                    <div class="message-meta">
                        <span><i class="fa-regular fa-clock me-1"></i>${msg.createdAt}</span>
                    </div>
                </div>
            `;
            container.append(msgHtml);
        }

        // Create new session via form
        function onCreateSession(event) {
            event.preventDefault();
            const title = $("#sessionTitleInput").val();
            const subjectId = $("#subjectSelectInput").val();

            $("#createSessionBtn").prop("disabled", true).text("Đang tạo...");

            $.post("/Chat/CreateSession", { subjectId: subjectId, title: title }, function (session) {
                $("#newSessionModal").modal("hide");
                
                // Reset form inputs
                $("#createSessionForm")[0].reset();
                $("#createSessionBtn").prop("disabled", false).text("Bắt đầu chat");

                activeSessionId = session.id;
                loadSessions();
                
                // Select and load this newly created session
                setTimeout(() => {
                    selectSession(session.id);
                }, 300);

            }).fail(function () {
                alert("Không thể tạo phiên chat mới. Vui lòng kiểm tra lại kết nối.");
                $("#createSessionBtn").prop("disabled", false).text("Bắt đầu chat");
            });
        }

        // Send a message
        function onSendMessage(event) {
            event.preventDefault();
            const input = $("#messageInput");
            const content = input.val().trim();
            if (!content || !activeSessionId) return;

            // Clear input
            input.val("");

            // Add user message to UI immediately
            const tempUserMsg = {
                id: Date.now(),
                role: "User",
                content: content,
                createdAt: new Date().toLocaleTimeString('vi-VN', { hour: '2-digit', minute: '2-digit', second: '2-digit' })
            };
            
            // Remove empty state if visible
            $(".empty-state").remove();
            renderMessage(tempUserMsg);
            scrollToBottom();

            // Disable input and button
            input.prop("disabled", true);
            $("#sendBtn").prop("disabled", true);

            // Add skeleton thinking state
            const skeletonId = `skeleton-${Date.now()}`;
            const skeletonHtml = `
                <div class="message-container assistant" id="${skeletonId}">
                    <div class="message-bubble">
                        <div class="skeleton-thinking">
                            <div class="skeleton-line medium"></div>
                            <div class="skeleton-line"></div>
                            <div class="skeleton-line short"></div>
                        </div>
                    </div>
                    <div class="message-meta">
                        <span><i class="fa-solid fa-spinner fa-spin me-1"></i>AI đang suy nghĩ...</span>
                    </div>
                </div>
            `;
            $("#chatMessages").append(skeletonHtml);
            scrollToBottom();

            // POST to SendMessage
            $.post("/Chat/SendMessage", { sessionId: activeSessionId, content: content }, function (assistantMsg) {
                // Remove skeleton thinking state
                $(`#${skeletonId}`).remove();

                // Enable inputs
                input.prop("disabled", false).focus();
                $("#sendBtn").prop("disabled", false);

                // Render assistant message
                renderMessage(assistantMsg);
                scrollToBottom();

                // Reload sessions to update counts and title in sidebar
                loadSessions();
            }).fail(function (xhr) {
                $(`#${skeletonId}`).remove();
                input.prop("disabled", false);
                $("#sendBtn").prop("disabled", false);

                const errBubble = `
                    <div class="message-container assistant">
                        <div class="message-bubble border-danger text-danger">
                            <i class="fa-solid fa-circle-exclamation me-1"></i> Có lỗi xảy ra khi gửi tin nhắn: ${xhr.responseText || "Vui lòng thử lại."}
                        </div>
                    </div>
                `;
                $("#chatMessages").append(errBubble);
                scrollToBottom();
            });
        }

        // Delete session
        function onDeleteSession(event, id) {
            event.stopPropagation(); // Avoid selecting session
            if (!confirm("Bạn có chắc chắn muốn xóa cuộc trò chuyện này?")) return;

            $.post("/Chat/DeleteSession", { id: id }, function (response) {
                if (response.success) {
                    if (activeSessionId === id) {
                        activeSessionId = null;
                        // Reset chat area
                        $("#chatHeader").addClass("d-none");
                        $("#chatInputArea").addClass("d-none");
                        $("#chatMessages").html(`
                            <div class="empty-state">
                                <i class="fa-solid fa-comments"></i>
                                <h4>Hộp thoại trống</h4>
                                <p>Hãy chọn một cuộc hội thoại từ menu bên trái hoặc bắt đầu một phiên chat mới để học tập cùng AI.</p>
                            </div>
                        `);
                    }
                    loadSessions();
                } else {
                    alert("Không thể xóa cuộc trò chuyện.");
                }
            }).fail(function () {
                alert("Lỗi kết nối khi xóa cuộc hội thoại.");
            });
        }

        // Utilities
        function scrollToBottom() {
            const container = document.getElementById("chatMessages");
            container.scrollTop = container.scrollHeight;
        }

        function escapeHtml(unsafe) {
            return unsafe
                 .replace(/&/g, "&amp;")
                 .replace(/</g, "&lt;")
                 .replace(/>/g, "&gt;")
                 .replace(/"/g, "&quot;")
                 .replace(/'/g, "&#039;");
        }
    </script>
}
