@model IEnumerable<Assignment1_PRN222_Group7_DAL.Entities.Experiment>
@{
    ViewData["Title"] = "Experiments";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-flask"></i> Experiments</h2>
        @if (User.IsInRole("Admin") || User.IsInRole("Lecturer"))
        {
            <a asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Create New Experiment
            </a>
        }
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle"></i> No experiments found. Create your first experiment to get started.
        </div>
    }
    else
    {
        <div class="card shadow-sm">
            <div class="card-body">
                <table class="table table-hover">
                    <thead class="table-light">
                        <tr>
                            <th>Name</th>
                            <th>Subject</th>
                            <th>Status</th>
                            <th>Configurations</th>
                            <th>Questions</th>
                            <th>Created</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <a asp-action="Details" asp-route-id="@item.Id" class="text-decoration-none fw-bold">
                                        @Html.DisplayFor(modelItem => item.Name)
                                    </a>
                                </td>
                                <td>@(item.Subject?.Name ?? "N/A")</td>
                                <td>
                                    @{
                                        var statusClass = item.Status switch
                                        {
                                            Assignment1_PRN222_Group7_DAL.Enums.ExperimentStatus.Draft => "bg-secondary",
                                            Assignment1_PRN222_Group7_DAL.Enums.ExperimentStatus.Running => "bg-warning text-dark",
                                            Assignment1_PRN222_Group7_DAL.Enums.ExperimentStatus.Completed => "bg-success",
                                            Assignment1_PRN222_Group7_DAL.Enums.ExperimentStatus.Failed => "bg-danger",
                                            _ => "bg-secondary"
                                        };
                                    }
                                    <span class="badge @statusClass">@item.Status</span>
                                </td>
                                <td><span class="badge bg-info">@item.Configurations?.Count()</span></td>
                                <td><span class="badge bg-primary">@item.TestQuestions?.Count()</span></td>
                                <td>@item.CreatedAt.ToLocalTime().ToString("MMM dd, yyyy")</td>
                                <td>
                                    <div class="btn-group btn-group-sm">
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-primary" title="Details">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        @if (item.Results?.Any() == true)
                                        {
                                            <a asp-action="Dashboard" asp-route-id="@item.Id" class="btn btn-outline-success" title="Dashboard">
                                                <i class="bi bi-graph-up"></i>
                                            </a>
                                        }
                                        @if (User.IsInRole("Admin") || User.IsInRole("Lecturer"))
                                        {
                                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-warning" title="Edit">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            @if (User.IsInRole("Admin"))
                                            {
                                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger" title="Delete">
                                                    <i class="bi bi-trash"></i>
                                                </a>
                                            }
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>
