@model Assignment1_PRN222_Group7.Models.ExperimentViewModels.TestQuestionFormViewModel
@{
    ViewData["Title"] = "Add Test Question";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0"><i class="bi bi-plus-circle"></i> Add Test Question</h4>
                    <small>Experiment: @ViewBag.ExperimentName</small>
                </div>
                <div class="card-body">
                    <form asp-action="AddTestQuestion" method="post">
                        @Html.AntiForgeryToken()

                        <input type="hidden" asp-for="ExperimentId" />

                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                        <div class="mb-3">
                            <label asp-for="OrderIndex" class="form-label fw-bold">Order Index</label>
                            <input asp-for="OrderIndex" class="form-control" type="number" min="1" />
                            <small class="text-muted">The order of this question in the test set</small>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Question" class="form-label fw-bold">Question *</label>
                            <textarea asp-for="Question" class="form-control" rows="3" 
                                      placeholder="Enter the test question..."></textarea>
                            <span asp-validation-for="Question" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="GroundTruth" class="form-label fw-bold">Ground Truth Answer *</label>
                            <textarea asp-for="GroundTruth" class="form-control" rows="4" 
                                      placeholder="Enter the correct/expected answer..."></textarea>
                            <small class="text-muted">The correct answer prepared by human expert</small>
                            <span asp-validation-for="GroundTruth" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ReferenceContext" class="form-label">Reference Context</label>
                            <textarea asp-for="ReferenceContext" class="form-control" rows="3" 
                                      placeholder="Optional reference context for this question..."></textarea>
                            <small class="text-muted">Optional: The source document/context for answering this question</small>
                        </div>

                        <div class="d-flex justify-content-between mt-4">
                            <a asp-action="Details" asp-route-id="@Model.ExperimentId" class="btn btn-secondary">
                                <i class="bi bi-arrow-left"></i> Back
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-save"></i> Add Question
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
