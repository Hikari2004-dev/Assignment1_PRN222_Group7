@model Assignment1_PRN222_Group7.Models.ExperimentViewModels.ConfigurationFormViewModel
@{
    ViewData["Title"] = "Add Configuration";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0"><i class="bi bi-plus-circle"></i> Add Configuration</h4>
                    <small>Experiment: @ViewBag.ExperimentName</small>
                </div>
                <div class="card-body">
                    <form asp-action="AddConfiguration" method="post">
                        @Html.AntiForgeryToken()

                        <input type="hidden" asp-for="ExperimentId" />

                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                        <div class="mb-3">
                            <label asp-for="ConfigName" class="form-label fw-bold">Configuration Name *</label>
                            <input asp-for="ConfigName" class="form-control" placeholder="e.g., RAG-Recursive-multilingual-e5" />
                            <span asp-validation-for="ConfigName" class="text-danger"></span>
                        </div>

                        <hr />
                        <h6 class="text-muted mb-3">Chunking Settings</h6>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="ChunkingStrategy" class="form-label">Chunking Strategy</label>
                                <select asp-for="ChunkingStrategy" class="form-select">
                                    <option value="Fixed">Fixed</option>
                                    <option value="Recursive">Recursive</option>
                                    <option value="Semantic">Semantic</option>
                                    <option value="Sentence">Sentence</option>
                                </select>
                            </div>
                            <div class="col-md-3 mb-3">
                                <label asp-for="ChunkSize" class="form-label">Chunk Size</label>
                                <input asp-for="ChunkSize" class="form-control" type="number" min="100" max="2000" />
                            </div>
                            <div class="col-md-3 mb-3">
                                <label asp-for="ChunkOverlap" class="form-label">Overlap</label>
                                <input asp-for="ChunkOverlap" class="form-control" type="number" min="0" max="500" />
                            </div>
                        </div>

                        <hr />
                        <h6 class="text-muted mb-3">Embedding & Retrieval Settings</h6>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="EmbeddingModel" class="form-label">Embedding Model</label>
                                <select asp-for="EmbeddingModel" class="form-select">
                                    <option value="MultilingualE5Base">Multilingual E5 Base (Free)</option>
                                    <option value="TextEmbedding3Small">Text Embedding 3 Small (OpenAI)</option>
                                    <option value="PhoBERTBase">PhoBERT Base (Vietnamese)</option>
                                    <option value="BgeM3">BGE M3 (BAAI)</option>
                                </select>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="RetrievalMethod" class="form-label">Retrieval Method</label>
                                <select asp-for="RetrievalMethod" class="form-select">
                                    <option value="RAG">RAG</option>
                                    <option value="FineTuned">Fine-tuned</option>
                                    <option value="Hybrid">Hybrid</option>
                                </select>
                            </div>
                        </div>

                        <hr />
                        <h6 class="text-muted mb-3">Search Settings</h6>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="TopK" class="form-label">Top K (Chunks to retrieve)</label>
                                <input asp-for="TopK" class="form-control" type="number" min="1" max="20" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="SimilarityThreshold" class="form-label">Similarity Threshold</label>
                                <input asp-for="SimilarityThreshold" class="form-control" type="number" step="0.01" min="0" max="1" />
                            </div>
                        </div>

                        <div class="d-flex justify-content-between mt-4">
                            <a asp-action="Details" asp-route-id="@Model.ExperimentId" class="btn btn-secondary">
                                <i class="bi bi-arrow-left"></i> Back
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-save"></i> Add Configuration
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
