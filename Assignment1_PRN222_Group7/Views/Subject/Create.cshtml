@{
    ViewData["Title"] = "Thêm môn học";
    var f = Context.Request.HasFormContentType ? Context.Request.Form : null;
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Index">Môn học</a></li>
        <li class="breadcrumb-item active">Thêm mới</li>
    </ol>
</nav>

<div class="card shadow-sm border-0" style="border-radius:14px;max-width:540px">
    <div class="card-body p-4">
        <h2 class="h5 fw-bold mb-4">➕ Thêm môn học mới</h2>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger">
                @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <div>@err.ErrorMessage</div>
                }
            </div>
        }

        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()

            <div class="mb-3">
                <label class="form-label fw-semibold" for="code">Mã môn học <span class="text-danger">*</span></label>
                <input id="code" name="code" type="text" class="form-control"
                       placeholder="Ví dụ: PRN222" required maxlength="20"
                       value="@(f?["code"].ToString().ToUpper())" />
                <div class="form-text">Sẽ được tự động chuyển thành CHỮ HOA.</div>
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold" for="name">Tên môn học <span class="text-danger">*</span></label>
                <input id="name" name="name" type="text" class="form-control"
                       placeholder="Ví dụ: Cross-Platform Programming" required maxlength="200"
                       value="@f?["name"]" />
            </div>

            <div class="mb-4">
                <label class="form-label fw-semibold" for="description">Mô tả</label>
                <textarea id="description" name="description" class="form-control" rows="3"
                          placeholder="Mô tả ngắn về môn học (không bắt buộc)">@f?["description"]</textarea>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary rounded-pill px-4">Lưu</button>
                <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">Hủy</a>
            </div>
        </form>
    </div>
</div>
