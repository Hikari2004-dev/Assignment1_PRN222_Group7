@model Assignment1_PRN222_Group7_DAL.Entities.Subject
@{
    ViewData["Title"] = "Chi tiết môn học";
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Index">Môn học</a></li>
        <li class="breadcrumb-item active">Chi tiết</li>
    </ol>
</nav>

<div class="card shadow-sm border-0" style="border-radius:14px;max-width:640px">
    <div class="card-body p-4">
        <div class="d-flex align-items-center gap-3 mb-3">
            <span class="badge bg-primary fs-6 px-3 py-2">@Model.Code</span>
            <h2 class="h4 fw-bold mb-0">@Model.Name</h2>
            @if (!Model.IsActive)
            {
                <span class="badge bg-secondary">Đã ẩn</span>
            }
        </div>

        @if (!string.IsNullOrEmpty(Model.Description))
        {
            <p class="text-muted">@Model.Description</p>
        }

        <hr />
        <dl class="row small">
            <dt class="col-sm-4 text-muted">Ngày tạo</dt>
            <dd class="col-sm-8">@Model.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</dd>

            <dt class="col-sm-4 text-muted">Số chương</dt>
            <dd class="col-sm-8">@Model.Chapters.Count</dd>

            @if (Model.Creator != null)
            {
                <dt class="col-sm-4 text-muted">Người tạo</dt>
                <dd class="col-sm-8">@Model.Creator.FullName</dd>
            }
        </dl>

        <div class="d-flex gap-2 mt-3 flex-wrap">
            <a asp-controller="Chapter" asp-action="Index" asp-route-subjectId="@Model.Id"
               class="btn btn-primary rounded-pill px-4">
                <i class="bi bi-list-ul me-1"></i>Xem chương
            </a>
            <a asp-controller="Document" asp-action="Index" asp-route-subjectId="@Model.Id"
               class="btn btn-success rounded-pill px-4">
                <i class="bi bi-file-earmark-text me-1"></i>Tài liệu
            </a>
            @if (User.IsInRole("Admin") || User.IsInRole("Lecturer"))
            {
                <a asp-action="Edit" asp-route-id="@Model.Id"
                   class="btn btn-outline-warning rounded-pill px-4">Sửa</a>
            }
            <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">← Quay lại</a>
        </div>
    </div>
</div>
