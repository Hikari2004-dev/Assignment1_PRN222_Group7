@model IEnumerable<Assignment1_PRN222_Group7_DAL.Entities.Chapter>
@{
    var subject = (Assignment1_PRN222_Group7_DAL.Entities.Subject)ViewBag.Subject;
    ViewData["Title"] = $"Chương - {subject.Name}";
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Subject" asp-action="Index">Môn học</a></li>
        <li class="breadcrumb-item"><a asp-controller="Subject" asp-action="Details" asp-route-id="@subject.Id">@subject.Code</a></li>
        <li class="breadcrumb-item active">Chương</li>
    </ol>
</nav>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h4 fw-bold mb-0">📖 Chương — @subject.Name</h1>
        <span class="badge bg-primary rounded-pill mt-1">@subject.Code</span>
    </div>
    @if (User.IsInRole("Admin") || User.IsInRole("Lecturer"))
    {
        <a asp-controller="Chapter" asp-action="Create" asp-route-subjectId="@subject.Id"
           class="btn btn-primary rounded-pill px-4">
            <i class="bi bi-plus-lg me-1"></i> Thêm chương
        </a>
    }
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (!Model.Any())
{
    <div class="text-center py-5 text-muted">
        <div style="font-size:3rem">📭</div>
        <p>Chưa có chương nào. Hãy thêm chương đầu tiên!</p>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th style="width:60px">#</th>
                    <th>Tiêu đề</th>
                    <th>Mô tả</th>
                    <th style="width:140px">Ngày tạo</th>
                    <th style="width:100px">Tài liệu</th>
                    <th style="width:160px"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var chapter in Model)
                {
                    <tr>
                        <td><span class="badge bg-secondary rounded-pill">@chapter.OrderIndex</span></td>
                        <td class="fw-semibold">@chapter.Title</td>
                        <td class="text-muted small">@(chapter.Description ?? "—")</td>
                        <td class="text-muted small">@chapter.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy")</td>
                        <td>
                            <a asp-controller="Document" asp-action="Index"
                               asp-route-subjectId="@subject.Id" asp-route-chapterId="@chapter.Id"
                               class="btn btn-sm btn-outline-success rounded-pill">
                                📄 @chapter.Documents.Count
                            </a>
                        </td>
                        <td>
                            <div class="d-flex gap-1">
                                @if (User.IsInRole("Admin") || User.IsInRole("Lecturer"))
                                {
                                    <a asp-controller="Chapter" asp-action="Edit"
                                       asp-route-subjectId="@subject.Id" asp-route-id="@chapter.Id"
                                       class="btn btn-sm btn-outline-warning rounded-pill">Sửa</a>
                                }
                                @if (User.IsInRole("Admin"))
                                {
                                    <a asp-controller="Chapter" asp-action="Delete"
                                       asp-route-subjectId="@subject.Id" asp-route-id="@chapter.Id"
                                       class="btn btn-sm btn-outline-danger rounded-pill">Xóa</a>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<div class="mt-3">
    <a asp-controller="Subject" asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">← Quay lại</a>
</div>
