@model Assignment1_PRN222_Group7_DAL.Entities.Chapter
@{
    var subject = (Assignment1_PRN222_Group7_DAL.Entities.Subject)ViewBag.Subject;
    ViewData["Title"] = "Xóa chương";
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Subject" asp-action="Index">Môn học</a></li>
        <li class="breadcrumb-item">
            <a asp-controller="Chapter" asp-action="Index" asp-route-subjectId="@subject.Id">@subject.Code</a>
        </li>
        <li class="breadcrumb-item active">Xóa chương</li>
    </ol>
</nav>

<div class="card border-danger shadow-sm" style="border-radius:14px;max-width:540px">
    <div class="card-body p-4">
        <h2 class="h5 fw-bold text-danger mb-3">⚠️ Xác nhận xóa chương</h2>
        <p class="text-muted">Hành động này không thể hoàn tác.</p>

        <dl class="row">
            <dt class="col-sm-4">Môn học</dt>
            <dd class="col-sm-8">@subject.Name (@subject.Code)</dd>

            <dt class="col-sm-4">Tiêu đề</dt>
            <dd class="col-sm-8 fw-semibold">@Model.Title</dd>

            <dt class="col-sm-4">Thứ tự</dt>
            <dd class="col-sm-8">@Model.OrderIndex</dd>
        </dl>

        <form asp-controller="Chapter" asp-action="Delete"
              asp-route-subjectId="@subject.Id" asp-route-id="@Model.Id"
              method="post" class="d-flex gap-2 mt-3">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-danger rounded-pill px-4">Xác nhận xóa</button>
            <a asp-controller="Chapter" asp-action="Index" asp-route-subjectId="@subject.Id"
               class="btn btn-outline-secondary rounded-pill px-4">Hủy</a>
        </form>
    </div>
</div>
