@{
    var subject = (Assignment1_PRN222_Group7_DAL.Entities.Subject)ViewBag.Subject;
    var chapters = (IEnumerable<Assignment1_PRN222_Group7_DAL.Entities.Chapter>)ViewBag.Chapters;
    ViewData["Title"] = $"Upload tài liệu - {subject.Name}";
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Subject" asp-action="Index">Môn học</a></li>
        <li class="breadcrumb-item"><a asp-controller="Subject" asp-action="Details" asp-route-id="@subject.Id">@subject.Code</a></li>
        <li class="breadcrumb-item"><a asp-controller="Document" asp-action="Index" asp-route-subjectId="@subject.Id">Tài liệu</a></li>
        <li class="breadcrumb-item active">Upload</li>
    </ol>
</nav>

<h1 class="h4 fw-bold mb-4">📤 Upload tài liệu — @subject.Name</h1>

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow-sm">
            <div class="card-body">
                <form asp-controller="Document" asp-action="Upload" asp-route-subjectId="@subject.Id"
                      method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label for="title" class="form-label fw-semibold">Tiêu đề <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="title" name="title"
                               placeholder="VD: Slide chương 1 - Giới thiệu lập trình" required />
                        @Html.ValidationMessage("title", new { @class = "text-danger small" })
                    </div>

                    <div class="mb-3">
                        <label for="chapterId" class="form-label fw-semibold">Chương (tuỳ chọn)</label>
                        <select class="form-select" id="chapterId" name="chapterId">
                            <option value="">— Không gắn chương —</option>
                            @foreach (var ch in chapters)
                            {
                                <option value="@ch.Id">@ch.Title</option>
                            }
                        </select>
                    </div>

                    <div class="mb-4">
                        <label for="file" class="form-label fw-semibold">Chọn file <span class="text-danger">*</span></label>
                        <input type="file" class="form-control" id="file" name="file"
                               accept=".pdf,.docx,.pptx,.txt" required />
                        <div class="form-text">Hỗ trợ: PDF, DOCX, PPTX, TXT. Tối đa 50 MB.</div>
                        @Html.ValidationMessage("file", new { @class = "text-danger small" })
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary rounded-pill px-4">
                            <i class="bi bi-upload me-1"></i> Upload
                        </button>
                        <a asp-controller="Document" asp-action="Index" asp-route-subjectId="@subject.Id"
                           class="btn btn-outline-secondary rounded-pill px-4">Hủy</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
