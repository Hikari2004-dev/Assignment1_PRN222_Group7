@{
    ViewData["Title"] = "Từ chối truy cập";
}

<div class="d-flex align-items-center justify-content-center min-vh-75 py-5">
    <div class="card card-denied border-0 shadow-lg p-5 rounded-4 text-center">
        <div class="icon-container mb-4 text-danger d-inline-flex align-items-center justify-content-center rounded-circle">
            <svg width="64" height="64" fill="currentColor" viewBox="0 0 16 16">
                <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14zm0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16z"/>
                <path d="M7.002 11a1 1 0 1 1 2 0 1 1 0 0 1-2 0zM7.1 4.995a.905.905 0 1 1 1.8 0l-.35 3.507a.552.552 0 0 1-1.1 0L7.1 4.995z"/>
            </svg>
        </div>
        
        <h2 class="fw-bold text-gradient mb-3">Từ Chối Truy Cập</h2>
        <p class="text-secondary mb-4">Bạn không có quyền hạn truy cập vào trang này. Vui lòng liên hệ quản trị viên hoặc đăng nhập bằng tài khoản có quyền truy cập phù hợp.</p>
        
        <div class="d-flex flex-column flex-sm-row gap-3 justify-content-center">
            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary px-4 py-2.5 rounded-3 fw-semibold">
                Quay về Trang chủ
            </a>
            
            <form asp-controller="Account" asp-action="Logout" method="post" style="display: inline;">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-danger-gradient text-white px-4 py-2.5 rounded-3 fw-semibold w-100">
                    Đăng nhập tài khoản khác
                </button>
            </form>
        </div>
    </div>
</div>

<style>
    .min-vh-75 {
        min-height: 75vh;
    }

    .card-denied {
        max-width: 550px;
        width: 100%;
        background-color: #ffffff;
        border: 1px solid rgba(0, 0, 0, 0.05) !important;
    }

    .icon-container {
        width: 100px;
        height: 100px;
        background-color: rgba(220, 53, 69, 0.08);
        margin: 0 auto;
    }

    .text-gradient {
        background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .btn-danger-gradient {
        background: linear-gradient(135deg, #dc3545 0%, #c82333 100%);
        border: none;
        transition: opacity 0.2s;
    }

    .btn-danger-gradient:hover {
        opacity: 0.9;
        color: white;
    }
</style>
