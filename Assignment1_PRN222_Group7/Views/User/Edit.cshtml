@model Assignment1_PRN222_Group7_DAL.Entities.User
@{
    ViewData["Title"] = "Chỉnh sửa thành viên";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card shadow border-0 rounded-3 my-4">
            <div class="card-body p-4">
                <div class="d-flex align-items-center mb-4">
                    <a asp-action="Index" class="btn btn-sm btn-outline-secondary rounded-pill me-3">
                        <i class="bi bi-arrow-left"></i> Quay lại
                    </a>
                    <h2 class="h4 fw-bold mb-0">Chỉnh sửa thông tin thành viên</h2>
                </div>

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger" role="alert">
                        <div asp-validation-summary="ModelOnly" class="text-danger small"></div>
                    </div>
                }

                <form asp-action="Edit" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />

                    <!-- Họ tên -->
                    <div class="mb-3">
                        <label class="form-label fw-semibold small">Họ và tên</label>
                        <input type="text" name="fullName" value="@Model.FullName" class="form-control" required />
                    </div>

                    <!-- Email -->
                    <div class="mb-3">
                        <label class="form-label fw-semibold small">Địa chỉ Email</label>
                        <input type="email" name="email" value="@Model.Email" class="form-control" required />
                    </div>

                    <!-- Vai trò -->
                    <div class="mb-3">
                        <label class="form-label fw-semibold small">Vai trò</label>
                        <select name="roleId" class="form-select" required>
                            @{
                                var roles = ViewBag.Roles as List<Assignment1_PRN222_Group7_DAL.Entities.Role>;
                            }
                            @if (roles != null)
                            {
                                @foreach (var role in roles)
                                {
                                    <option value="@role.Id" selected="@(Model.RoleId == role.Id)">@role.Description</option>
                                }
                            }
                            <!-- Nếu là Admin, cho hiển thị luôn Admin (RoleId=3) -->
                            @if (Model.RoleId == 3)
                            {
                                <option value="3" selected>Quản trị viên (Admin)</option>
                            }
                        </select>
                    </div>

                    <!-- Mã số Sinh viên / Giảng viên -->
                    <div class="mb-3">
                        <label class="form-label fw-semibold small">Mã số (MSSV hoặc MSGV)</label>
                        <input type="text" name="studentOrStaffId" value="@Model.StudentOrStaffId" class="form-control" placeholder="Ví dụ: SE170254, GV101..." />
                    </div>

                    <div class="card bg-light border-0 p-3 mb-4 rounded-3">
                        <h6 class="fw-bold small mb-2 text-dark"><i class="bi bi-shield-lock me-1"></i>Thay đổi mật khẩu (Tùy chọn)</h6>
                        <p class="text-muted small mb-3">Chỉ nhập nếu bạn muốn đổi mật khẩu mới cho tài khoản này.</p>
                        
                        <div class="mb-2">
                            <label class="form-label small">Mật khẩu mới</label>
                            <input type="password" name="password" class="form-control bg-white" placeholder="Bỏ trống để giữ nguyên" />
                        </div>
                        <div>
                            <label class="form-label small">Xác nhận mật khẩu</label>
                            <input type="password" name="confirmPassword" class="form-control bg-white" placeholder="Bỏ trống để giữ nguyên" />
                        </div>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 rounded-pill py-2 fw-semibold">
                        Lưu thay đổi
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
