@page "/Subject/{subjectId:int}/Chapter/Edit/{id:int}"
@model Assignment1_PRN222_Group7.Pages.Chapter.EditModel
@{
    ViewData["Title"] = "Sửa chương";
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-page="/Subject/Index">Môn học</a></li>
        <li class="breadcrumb-item">
            <a asp-page="/Chapter/Index" asp-route-subjectId="@Model.Subject.Id">@Model.Subject.Code</a>
        </li>
        <li class="breadcrumb-item active">Sửa chương</li>
    </ol>
</nav>

<div class="card shadow-sm border-0" style="border-radius:14px;max-width:540px">
    <div class="card-body p-4">
        <h2 class="h5 fw-bold mb-1">✏️ Sửa chương</h2>
        <p class="text-muted small mb-4">Môn: <strong>@Model.Subject.Name (@Model.Subject.Code)</strong></p>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger">
                @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <div>@err.ErrorMessage</div>
                }
            </div>
        }

        <form method="post">
            <div class="mb-3">
                <label class="form-label fw-semibold" for="title">Tiêu đề chương <span class="text-danger">*</span></label>
                <input id="title" asp-for="Title" class="form-control" required maxlength="300" />
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold" for="description">Mô tả</label>
                <textarea id="description" asp-for="Description" class="form-control" rows="3"></textarea>
            </div>

            <div class="mb-4">
                <label class="form-label fw-semibold" for="orderIndex">Thứ tự (OrderIndex)</label>
                <input id="orderIndex" asp-for="OrderIndex" type="number" class="form-control" min="0" />
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-warning rounded-pill px-4">Lưu thay đổi</button>
                <a asp-page="/Chapter/Index" asp-route-subjectId="@Model.Subject.Id"
                   class="btn btn-outline-secondary rounded-pill px-4">Hủy</a>
            </div>
        </form>
    </div>
</div>
