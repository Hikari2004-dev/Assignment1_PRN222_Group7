@page
@model Assignment1_PRN222_Group7.Pages.Subject.DeleteModel
@{
    ViewData["Title"] = "Xóa môn học";
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-page="./Index">Môn học</a></li>
        <li class="breadcrumb-item active">Xóa</li>
    </ol>
</nav>

<div class="card border-danger shadow-sm" style="border-radius:14px;max-width:540px">
    <div class="card-body p-4">
        <h2 class="h5 fw-bold text-danger mb-3">⚠️ Xác nhận xóa môn học</h2>
        <p class="text-muted">Hành động này không thể hoàn tác. Tất cả chương liên quan cũng sẽ bị xóa.</p>

        <dl class="row">
            <dt class="col-sm-4">Mã môn</dt>
            <dd class="col-sm-8 fw-semibold">@Model.Subject.Code</dd>

            <dt class="col-sm-4">Tên môn</dt>
            <dd class="col-sm-8">@Model.Subject.Name</dd>

            <dt class="col-sm-4">Số chương</dt>
            <dd class="col-sm-8">@Model.Subject.Chapters.Count</dd>
        </dl>

        <form method="post" class="d-flex gap-2 mt-3">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-danger rounded-pill px-4">Xác nhận xóa</button>
            <a asp-page="./Index" class="btn btn-outline-secondary rounded-pill px-4">Hủy</a>
        </form>
    </div>
</div>
