@page
@model Assignment1_PRN222_Group7.Pages.User.AssignSubjectsModel
@{
    ViewData["Title"] = "Phân quyền môn học";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="card shadow border-0 rounded-3 my-4">
            <div class="card-body p-4">
                <div class="d-flex align-items-center mb-4">
                    <a asp-page="./Index" class="btn btn-sm btn-outline-secondary rounded-pill me-3">
                        <i class="bi bi-arrow-left"></i> Quay lại
                    </a>
                    <h2 class="h4 fw-bold mb-0">Phân quyền môn học</h2>
                </div>

                <div class="mb-4">
                    <p class="mb-1 text-muted small">Giảng viên:</p>
                    <h5 class="fw-bold">@Model.Lecturer.FullName</h5>
                    <span class="text-muted small">@Model.Lecturer.Email</span>
                </div>

                <form method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Lecturer.Id" />

                    <label class="form-label fw-bold small mb-2"><i class="bi bi-journal-bookmark me-1"></i>Danh sách môn học</label>
                    <p class="text-muted small mb-3">Chọn các môn học giảng viên này được phép truy cập và quản lý:</p>

                    <div class="list-group mb-4" style="max-height: 300px; overflow-y: auto;">
                        @if (!Model.AllSubjects.Any())
                        {
                            <div class="list-group-item text-center py-3 text-muted small">
                                Không có môn học nào khả dụng để phân công (tất cả các môn học đã được phân phối cho giảng viên khác hoặc chưa được tạo).
                            </div>
                        }
                        else
                        {
                            @foreach (var subject in Model.AllSubjects)
                            {
                                <label class="list-group-item d-flex align-items-center gap-3 py-3 rounded-2 mb-2 border shadow-sm" style="cursor: pointer;">
                                    <input class="form-check-input flex-shrink-0" type="checkbox" name="SelectedSubjectIds" value="@subject.Id" @(Model.AssignedIds.Contains(subject.Id) ? "checked" : "")>
                                    <div>
                                        <span class="badge bg-primary-subtle text-primary rounded-pill mb-1">@subject.Code</span>
                                        <div class="fw-semibold text-dark">@subject.Name</div>
                                        @if (!string.IsNullOrEmpty(subject.Description))
                                        {
                                            <div class="text-muted small">@subject.Description</div>
                                        }
                                    </div>
                                </label>
                            }
                        }
                    </div>

                    <button type="submit" class="btn btn-primary w-100 rounded-pill py-2 fw-semibold" @(!Model.AllSubjects.Any() ? "disabled" : "")>
                        Lưu phân quyền
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
