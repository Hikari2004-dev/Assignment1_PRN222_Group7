@page "/Experiment/EditTestQuestion/{id:int}"
@model Assignment1_PRN222_Group7.Pages.Experiment.EditTestQuestionModel
@{
    ViewData["Title"] = "Edit Test Question";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-header bg-warning text-dark">
                    <h4 class="mb-0"><i class="bi bi-pencil"></i> Edit Test Question</h4>
                </div>
                <div class="card-body">
                    <form method="post">
                        <input type="hidden" asp-for="TestQuestionForm.Id" />
                        <input type="hidden" asp-for="TestQuestionForm.ExperimentId" />

                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                        <div class="mb-3">
                            <label asp-for="TestQuestionForm.OrderIndex" class="form-label fw-bold">Order Index</label>
                            <input asp-for="TestQuestionForm.OrderIndex" class="form-control" type="number" min="1" />
                        </div>

                        <div class="mb-3">
                            <label asp-for="TestQuestionForm.Question" class="form-label fw-bold">Question *</label>
                            <textarea asp-for="TestQuestionForm.Question" class="form-control" rows="3"></textarea>
                            <span asp-validation-for="TestQuestionForm.Question" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="TestQuestionForm.GroundTruth" class="form-label fw-bold">Ground Truth Answer *</label>
                            <textarea asp-for="TestQuestionForm.GroundTruth" class="form-control" rows="4"></textarea>
                            <small class="text-muted">The correct answer prepared by human expert</small>
                            <span asp-validation-for="TestQuestionForm.GroundTruth" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="TestQuestionForm.ReferenceContext" class="form-label">Reference Context</label>
                            <textarea asp-for="TestQuestionForm.ReferenceContext" class="form-control" rows="3"></textarea>
                            <small class="text-muted">Optional: The source document/context for answering this question</small>
                        </div>

                        <div class="d-flex justify-content-between mt-4">
                            <a asp-page="/Experiment/Details" asp-route-id="@Model.TestQuestionForm.ExperimentId" class="btn btn-secondary">
                                <i class="bi bi-arrow-left"></i> Back
                            </a>
                            <button type="submit" class="btn btn-warning">
                                <i class="bi bi-save"></i> Save Changes
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
