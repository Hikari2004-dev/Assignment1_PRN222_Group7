@page "/Experiment/Delete/{id:int}"
@model Assignment1_PRN222_Group7.Pages.Experiment.DeleteModel
@{
    ViewData["Title"] = "Delete Experiment";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow border-danger">
                <div class="card-header bg-danger text-white">
                    <h4 class="mb-0"><i class="bi bi-exclamation-triangle"></i> Delete Experiment</h4>
                </div>
                <div class="card-body">
                    <div class="alert alert-danger">
                        <strong>Warning:</strong> This action cannot be undone. All configurations, 
                        test questions, and results associated with this experiment will also be deleted.
                    </div>

                    <dl class="row">
                        <dt class="col-sm-4">Name</dt>
                        <dd class="col-sm-8">@Model.Experiment.Name</dd>

                        <dt class="col-sm-4">Subject</dt>
                        <dd class="col-sm-8">@Model.Experiment.Subject?.Name</dd>

                        <dt class="col-sm-4">Status</dt>
                        <dd class="col-sm-8">
                            <span class="badge bg-secondary">@Model.Experiment.Status</span>
                        </dd>

                        <dt class="col-sm-4">Created</dt>
                        <dd class="col-sm-8">@Model.Experiment.CreatedAt.ToLocalTime().ToString("MMM dd, yyyy HH:mm")</dd>

                        @if (!string.IsNullOrEmpty(Model.Experiment.Description))
                        {
                            <dt class="col-sm-4">Description</dt>
                            <dd class="col-sm-8">@Model.Experiment.Description</dd>
                        }
                    </dl>

                    <form method="post">
                        <input type="hidden" asp-for="Experiment.Id" />

                        <div class="d-flex justify-content-between">
                            <a asp-page="/Experiment/Details" asp-route-id="@Model.Experiment.Id" class="btn btn-secondary">
                                <i class="bi bi-arrow-left"></i> Cancel
                            </a>
                            <button type="submit" class="btn btn-danger">
                                <i class="bi bi-trash"></i> Delete Experiment
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
