@page "/Subject/{subjectId:int}/Document/Details/{id:int}"
@model Assignment1_PRN222_Group7.Pages.Document.DetailsModel
@{
    ViewData["Title"] = $"Chi tiết tài liệu - {Model.Document.Title}";
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-page="/Subject/Index">Môn học</a></li>
        <li class="breadcrumb-item"><a asp-page="/Subject/Details" asp-route-id="@Model.Subject.Id">@Model.Subject.Code</a></li>
        <li class="breadcrumb-item"><a asp-page="/Document/Index" asp-route-subjectId="@Model.Subject.Id">Tài liệu</a></li>
        <li class="breadcrumb-item active">Chi tiết</li>
    </ol>
</nav>

<style>
    .custom-tab-btn {
        border-radius: 6px !important;
        padding: 10px 24px !important;
        font-weight: bold !important;
        transition: all 0.2s ease;
    }
    .custom-tab-btn.active {
        background-color: #2b303c !important;
        color: #ffffff !important;
        border-color: #2b303c !important;
    }
    .custom-tab-btn:not(.active) {
        background-color: #ffffff !important;
        color: #495057 !important;
        border: 1px solid #dee2e6 !important;
    }
    .custom-tab-btn:not(.active):hover {
        background-color: #f8f9fa !important;
        border-color: #c1c9d0 !important;
    }
    .border-dashed {
        border-style: dashed !important;
        border-color: #6c757d !important;
    }
</style>

<div class="card shadow-sm border-0 mb-4 rounded-3 bg-white">
    <div class="card-body p-4">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-start gap-3">
            <div>
                <h1 class="h2 fw-bold text-uppercase mb-2 text-dark">@Model.Document.Title</h1>
                <div class="d-flex flex-wrap gap-2 align-items-center text-muted small">
                    <span>📄 Loại file: <strong>@Model.Document.FileType</strong></span>
                    <span>|</span>
                    <span>🕒 Cập nhật: <strong>@Model.Document.UploadedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</strong></span>
                    <span>|</span>
                    <span>👤 Người tải: <strong>@(Model.Document.Uploader?.FullName ?? "—")</strong></span>
                    <span>|</span>
                    <span class="badge bg-primary px-3 py-1.5 rounded-pill text-white fw-bold">@Model.Document.TotalChunks chunks</span>
                </div>
            </div>
            <div class="d-flex gap-2 align-self-md-center">
                @if (Model.Document.FileType == Assignment1_PRN222_Group7_DAL.Enums.FileType.PDF || Model.Document.FileType == Assignment1_PRN222_Group7_DAL.Enums.FileType.TXT)
                {
                    <a href="@Url.Page("/Document/Details", "InlineFile", new { subjectId = Model.Subject.Id, id = Model.Document.Id })"
                       target="_blank" class="btn btn-outline-secondary fw-bold px-4 py-2 rounded-3 shadow-sm d-flex align-items-center gap-1">
                        👁️ XEM TRONG TAB MỚI
                    </a>
                }
                <a asp-page="/Document/Index" asp-page-handler="Download" asp-route-subjectId="@Model.Subject.Id" asp-route-id="@Model.Document.Id"
                   target="_blank" class="btn btn-warning fw-bold px-4 py-2 text-dark rounded-3 shadow-sm d-flex align-items-center gap-1">
                    📥 TẢI XUỐNG
                </a>
                @if (Model.IsAssignedLecturer)
                {
                    <form asp-page="/Document/Index" asp-page-handler="ReIndex"
                          asp-route-subjectId="@Model.Subject.Id" asp-route-id="@Model.Document.Id" method="post" class="d-inline">
                        <button type="submit" class="btn btn-outline-primary fw-bold px-4 py-2 rounded-3 shadow-sm">
                            ⚡ RE-INDEX
                        </button>
                    </form>
                }
            </div>
        </div>
    </div>
</div>

<div class="card shadow-sm border-0 mb-4 rounded-3">
    <div class="card-header bg-white border-bottom-0 pt-3 px-4">
        <ul class="nav nav-pills card-header-pills" id="docTabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active custom-tab-btn me-2 text-uppercase" id="preview-tab" data-bs-toggle="tab" data-bs-target="#preview-pane" type="button" role="tab" aria-controls="preview-pane" aria-selected="true">
                    📄 NỘI DUNG
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link custom-tab-btn text-uppercase" id="chunks-tab" data-bs-toggle="tab" data-bs-target="#chunks-pane" type="button" role="tab" aria-controls="chunks-pane" aria-selected="false">
                    🧩 VECTOR CHUNKS (@Model.Document.TotalChunks)
                </button>
            </li>
        </ul>
    </div>
    <div class="card-body p-4 tab-content" id="docTabContent">
        <!-- TAB 1: PREVIEW -->
        <div class="tab-pane fade show active" id="preview-pane" role="tabpanel" aria-labelledby="preview-tab" tabindex="0">
            @if (Model.Document.FileType == Assignment1_PRN222_Group7_DAL.Enums.FileType.PDF)
            {
                <div class="ratio ratio-16x9 mb-3" style="height: 600px;">
                    <iframe src="@Url.Page("/Document/Details", "InlineFile", new { subjectId = Model.Subject.Id, id = Model.Document.Id })" 
                            class="rounded border shadow-sm w-100 h-100" 
                            style="border: none;"></iframe>
                </div>
            }
            else if (Model.Document.FileType == Assignment1_PRN222_Group7_DAL.Enums.FileType.TXT)
            {
                <div class="bg-white p-3 rounded border font-monospace text-dark overflow-auto" style="white-space: pre-wrap; line-height: 1.6; max-height: 600px;">
                    @if (string.IsNullOrEmpty(Model.TxtContent))
                    {
                        <p class="text-muted italic">File văn bản này trống hoặc không đọc được nội dung.</p>
                    }
                    else
                    {
                        @Model.TxtContent
                    }
                </div>
            }
            else
            {
                @if (Model.Chunks.Any())
                {
                    <div class="bg-light p-3 rounded border text-dark overflow-auto mb-3" style="max-height: 600px;">
                        <div class="alert alert-info py-2 small mb-3">
                            ℹ️ Đây là toàn bộ văn bản được trích xuất từ file Office gốc (@Model.Document.FileType). Bạn có thể đọc trực tiếp nội dung dưới đây:
                        </div>
                        <div class="bg-white p-3 rounded border font-monospace" style="white-space: pre-wrap; line-height: 1.6;">@string.Join("\n\n", Model.Chunks.Select(c => c.Content))</div>
                    </div>
                }
                else
                {
                    <div class="text-center py-5">
                        <div style="font-size: 3rem;">📁</div>
                        <h5 class="fw-bold mt-3">Định dạng file không hỗ trợ xem trực tiếp</h5>
                        <p class="text-muted mb-4">Các định dạng Office (Word, PowerPoint) chưa được index hoặc không hỗ trợ xem trực tiếp trực tuyến. Hãy tải file gốc về máy hoặc xem các mảnh từ ngữ do AI tách ở tab bên cạnh.</p>
                        <a asp-page="/Document/Index" asp-page-handler="Download" asp-route-subjectId="@Model.Subject.Id" asp-route-id="@Model.Document.Id"
                           target="_blank" class="btn btn-primary rounded-pill px-4">
                            <i class="bi bi-download me-1"></i> Tải file gốc
                        </a>
                    </div>
                }
            }
        </div>

        <!-- TAB 2: CHUNKS -->
        <div class="tab-pane fade" id="chunks-pane" role="tabpanel" aria-labelledby="chunks-tab" tabindex="0">
            <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-2">
                <span class="fw-bold text-secondary">Các đoạn văn bản (Chunks) đã Vector Embedding bằng Gemini AI.</span>
                @if (Model.Document.IsIndexed)
                {
                    <span class="badge bg-primary px-3 py-2 fw-bold text-uppercase">✓ ĐÃ VECTOR HÓA</span>
                }
                else
                {
                    <span class="badge bg-warning text-dark px-3 py-2 fw-bold text-uppercase">⚠️ CHƯA VECTOR HÓA</span>
                }
            </div>

            @if (!Model.Chunks.Any())
            {
                <div class="py-5 text-center text-muted">
                    <div style="font-size:3rem">🧩</div>
                    <p class="mt-2">Chưa có phân mảnh nào được tạo. Hãy nhấn **Re-index tài liệu** phía trên để phân mảnh và trích xuất vector!</p>
                </div>
            }
            else
            {
                <div class="d-flex flex-column gap-1">
                    @foreach (var chunk in Model.Chunks)
                    {
                        <div class="mb-3">
                            <div class="mb-2">
                                <span class="badge bg-primary px-3 py-2 fw-bold font-monospace text-uppercase" style="border-radius: 4px;">
                                    CHUNK #@(chunk.ChunkIndex + 1) | @(chunk.EmbeddingId != null && chunk.EmbeddingId.Length >= 8 ? chunk.EmbeddingId.Substring(0, 5).ToUpper() : $"ID_{chunk.Id}")
                                </span>
                            </div>
                            <div class="p-3 bg-light rounded border border-dashed font-monospace text-dark overflow-auto" 
                                 style="white-space: pre-wrap; line-height: 1.6; max-height: 250px; font-size: 0.9rem;">@chunk.Content</div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>

<div class="mt-3">
    <a asp-page="/Document/Index" asp-route-subjectId="@Model.Subject.Id" class="btn btn-outline-secondary rounded-pill px-4">← Quay lại</a>
</div>

@functions {
    static string FormatFileSize(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:F1} KB";
        return $"{bytes / (1024.0 * 1024):F1} MB";
    }
}
